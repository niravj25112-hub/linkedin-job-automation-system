APP_NAME="LinkedIn Job Automation System"
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/linkedin_jobs

JWT_SECRET_KEY=change-me-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:8000/api/v1/email/oauth/callback
GMAIL_SENDER_EMAIL=

JOB_SEARCH_LOOKBACK_HOURS=24
JOB_KEYWORDS="Java Developer C2C,Business Analyst C2C,Project Manager C2C,Data Analyst C2C"

